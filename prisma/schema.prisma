generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String   @id @default(cuid())
  steamId              String   @unique
  username             String?
  avatar               String?
  age                  Int?
  region               String?
  email                String?  @unique
  password             String?
  jeuPrincipal         String?
  typeTransportPrefere String?
  descriptionChauffeur String?
  styleConduite        String?
  micro                Boolean  @default(false)
  createdAt            DateTime @default(now())
  argent               Int      @default(0)
  argentPerso          Int      @default(0)
  parkingPlaces        Int      @default(0)

  camionsAttribues    Camion[]   @relation("CamionsAttribues")
  camionsPerso        Camion[]   @relation("CamionsPerso")
  remorquesAttribuees Remorque[] @relation("RemorquesAttribuees")

  chauffeurStats              ChauffeurStat[]
  entreprisesCreees           Entreprise?              @relation("EntrepriseOwner")
  candidatures                EntrepriseCandidature[]
  memberships                 EntrepriseMembre?
  finances                    Finance[]
  livraisons                  Livraison[]
  mouvementsCuve              MouvementCuve[]
  pleinsCarburant             PleinCarburant[]
  tackySessions               TackySession[]
  dlcs                        UserDlc[]
  livraisonsCarburantSite     LivraisonCarburantSite[]
  entretiensEffectues         CamionEntretien[]
  entretiensRemorqueEffectues RemorqueEntretien[]
  infractionsRecues           Infraction[]
  financesPerso               FinancePerso[]
  lastOnlineAt DateTime?
  lastMapX     Float?
  lastMapY     Float?
  lastHeading  Float?

  achatsCamionsOccasion VenteCamion[] @relation("AchatsCamionsOccasion")
}

model Entreprise {
  id                        Int      @id @default(autoincrement())
  nom                       String
  abreviation               String   @db.VarChar(3)
  villeETS2                 String?
  villeATS                  String?
  jeu                       String
  typeTransport             String
  description               String
  recrutement               Boolean  @default(true)
  banniere                  String?
  ownerSteamId              String   @unique
  createdAt                 DateTime @default(now())
  argent                    Int      @default(500000)
  cuveActuelle              Int      @default(6200)
  cuveMax                   Int      @default(10000)
  entrepriseId              String?
  discordUrl                String?
  discordWebhookAchatCamion String?
  discordWebhookDepart      String?
  discordWebhookLivraison   String?
  discordWebhookMaintenance String?
  discordWebhookRecrutement String?
  discordWebhookVenteCamion String?
  prixLitreCuve             Decimal  @default(1.35) @db.Decimal(10, 2)
  prixLitreHorsCuve         Decimal  @default(2.30) @db.Decimal(10, 2)

  telepeageActif      Boolean   @default(false)
  telepeageCamionsMax Int       @default(0)
  telepeagePrix       Int       @default(0)
  telepeageDateDebut  DateTime?
  telepeageDateFin    DateTime?

  camions                 Camion[]
  remorques               Remorque[]
  chauffeurStats          ChauffeurStat[]
  owner                   User                      @relation("EntrepriseOwner", fields: [ownerSteamId], references: [steamId], onDelete: Cascade)
  candidatures            EntrepriseCandidature[]
  membres                 EntrepriseMembre[]
  finances                Finance[]
  livraisons              Livraison[]
  mouvementsCuve          MouvementCuve[]
  pleinsCarburant         PleinCarburant[]
  avertissements          AvertissementEntreprise[]
  livraisonsCarburantSite LivraisonCarburantSite[]
  achatsCarburantSite     AchatCarburantSite[]
  entretiens              CamionEntretien[]
  entretiensRemorque      RemorqueEntretien[]
  infractionsRecues       Infraction[]
  contratsTelepeage       TelepeageContrat[]

  ventesCamionsOccasion VenteCamion[] @relation("VentesCamionsEntreprise")

  @@index([nom])
  @@index([jeu])
}

model EntrepriseMembre {
  id                   Int                       @id @default(autoincrement())
  userId               String                    @unique
  entrepriseId         Int
  role                 RoleEntreprise            @default(CHAUFFEUR)
  createdAt            DateTime                  @default(now())
  entreprise           Entreprise                @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avertissementsRecus  AvertissementEntreprise[] @relation("AvertissementMembre")
  avertissementsDonnes AvertissementEntreprise[] @relation("AvertissementAuteur")

  @@index([entrepriseId])
}

model EntrepriseCandidature {
  id             Int               @id @default(autoincrement())
  userId         String
  entrepriseId   Int
  age            Int?
  region         String?
  jeuPrincipal   String
  experience     String
  micro          Boolean           @default(false)
  disponibilites String?
  motivation     String
  message        String?
  statut         StatutCandidature @default(EN_ATTENTE)
  createdAt      DateTime          @default(now())
  entreprise     Entreprise        @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([userId])
  @@index([entrepriseId])
  @@index([statut])
}

model UserDlc {
  id        Int      @id @default(autoincrement())
  userId    String
  jeu       String
  nomDlc    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jeu, nomDlc])
  @@index([userId])
  @@index([jeu])
}

model Finance {
  id           Int             @id @default(autoincrement())
  entrepriseId Int
  chauffeurId  String?
  type         String
  description  String
  montant      Int
  createdAt    DateTime        @default(now())
  pleinId      String?
  chauffeur    User?           @relation(fields: [chauffeurId], references: [id])
  entreprise   Entreprise      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  plein        PleinCarburant? @relation(fields: [pleinId], references: [id])

  @@index([entrepriseId])
  @@index([chauffeurId])
  @@index([pleinId])
  @@index([createdAt])
  @@index([type])
}

model Camion {
  id                   Int          @id @default(autoincrement())
  entrepriseId         Int?
  marque               MarqueCamion
  modele               String
  image                String?
  kilometrage          Int          @default(0)
  etat                 Int          @default(100)
  carburant            Int          @default(100)
  positionActuelle     String?
  statut               StatutCamion @default(DISPONIBLE)
  vidangeRestante      Int          @default(60000)
  revisionRestante     Int          @default(120000)
  actif                Boolean      @default(true)
  createdAt            DateTime     @default(now())
  cabine               String?
  chassis              String?
  moteur               String?
  peinture             String?
  preuveAchat          String?
  transmission         String?
  accessoiresExterieur String?
  accessoiresInterieur String?
  prixAchat            Int?
  chauffeurAttribueId  String?
  proprietaireId       String?

  aVendre      Boolean   @default(false)
  prixVente    Int?
  misEnVenteAt DateTime?
  venduAt      DateTime?

  degatsMoteur      Int @default(0)
  degatsCarrosserie Int @default(0)
  degatsChassis     Int @default(0)
  degatsRoues       Int @default(0)

  pneusRestantsKm    Int @default(100000)
  freinsRestantsKm   Int @default(60000)
  batterieRestanteKm Int @default(150000)

  chauffeurAttribue User?             @relation("CamionsAttribues", fields: [chauffeurAttribueId], references: [id])
  entreprise        Entreprise?       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  proprietaire      User?             @relation("CamionsPerso", fields: [proprietaireId], references: [id])
  livraisons        Livraison[]
  pleins            PleinCarburant[]
  entretiens        CamionEntretien[]
  infractionsLiees  Infraction[]
  ventesOccasion    VenteCamion[]

  @@index([entrepriseId])
  @@index([chauffeurAttribueId])
  @@index([proprietaireId])
  @@index([statut])
  @@index([aVendre])
  @@index([prixVente])
}

model VenteCamion {
  id           Int      @id @default(autoincrement())
  camionId     Int
  entrepriseId Int
  acheteurId   String
  prixVente    Int
  kilometrage  Int      @default(0)
  createdAt    DateTime @default(now())

  camion     Camion     @relation(fields: [camionId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation("VentesCamionsEntreprise", fields: [entrepriseId], references: [id], onDelete: Cascade)
  acheteur   User       @relation("AchatsCamionsOccasion", fields: [acheteurId], references: [id], onDelete: Cascade)

  @@index([camionId])
  @@index([entrepriseId])
  @@index([acheteurId])
  @@index([createdAt])
}

model Remorque {
  id                  Int     @id @default(autoincrement())
  entrepriseId        Int
  chauffeurAttribueId String? @unique

  marque      MarqueRemorque
  modele      String
  type        TypeRemorque
  jeu         String
  image       String?
  description String?
  prixAchat   Int            @default(0)

  statut StatutRemorque @default(DISPONIBLE)
  actif  Boolean        @default(true)

  pneusUsure      Int @default(0)
  pneusRestantsKm Int @default(100000)

  degatsChassis   Int @default(0)
  degatsRoues     Int @default(0)
  degatsCaisse    Int @default(0)
  degatsCargaison Int @default(0)

  createdAt DateTime @default(now())

  entreprise        Entreprise          @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  chauffeurAttribue User?               @relation("RemorquesAttribuees", fields: [chauffeurAttribueId], references: [id])
  livraisons        Livraison[]
  entretiens        RemorqueEntretien[]

  @@index([entrepriseId])
  @@index([chauffeurAttribueId])
  @@index([statut])
  @@index([type])
}

model RemorqueEntretien {
  id           Int                   @id @default(autoincrement())
  remorqueId   Int
  entrepriseId Int
  userId       String?
  type         TypeEntretienRemorque
  prix         Int                   @default(0)
  commentaire  String?
  createdAt    DateTime              @default(now())

  remorque   Remorque   @relation(fields: [remorqueId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([remorqueId])
  @@index([entrepriseId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

model ChauffeurStat {
  id           Int        @id @default(autoincrement())
  userId       String
  entrepriseId Int
  argentGagne  Int        @default(0)
  kilometres   Int        @default(0)
  infractions  Int        @default(0)
  accidents    Int        @default(0)
  livraisons   Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
}

model ClientEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())
  deviceId  String?
  game      String?
  sessionId String?
  steamId   String?

  @@index([steamId])
  @@index([deviceId])
  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

model Livraison {
  id                String    @id @default(cuid())
  jobId             String?   @unique
  truck             String
  sourceCity        String?
  destinationCity   String?
  income            Int       @default(0)
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  status            String    @default("EN_COURS")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  steamId           String
  entrepriseId      Int?
  argentAjoute      Boolean   @default(false)
  distanceReelleKm  Float     @default(0)
  endOdometerKm     Float?
  kmPrevu           Int?
  startOdometerKm   Float     @default(0)
  cargo             String?
  camionId          Int?
  remorqueId        Int?
  cancelReason      String?
  deviceId          String?
  game              String?
  sessionId         String?
  truckBrand        String?
  truckModel        String?
  validatedByServer Boolean   @default(false)
  charges           Int       @default(0)
  gainChauffeur     Int       @default(0)
  gainSociete       Int       @default(0)

  trailerDamageChassis     Float @default(0)
  trailerDamageWheels      Float @default(0)
  trailerDamageBody        Float @default(0)
  trailerCargoDamage       Float @default(0)
  pourcentagePerteRemorque Int   @default(0)

  camion                 Camion?                 @relation(fields: [camionId], references: [id])
  remorque               Remorque?               @relation(fields: [remorqueId], references: [id])
  entreprise             Entreprise?             @relation(fields: [entrepriseId], references: [id])
  user                   User                    @relation(fields: [steamId], references: [steamId], onDelete: Cascade)
  pleins                 PleinCarburant[]
  livraisonCarburantSite LivraisonCarburantSite?

  @@index([steamId])
  @@index([entrepriseId])
  @@index([camionId])
  @@index([remorqueId])
  @@index([status])
  @@index([startedAt])
  @@index([finishedAt])
}

model PleinCarburant {
  id                String          @id @default(cuid())
  steamId           String
  entrepriseId      Int?
  camionId          Int?
  livraisonId       String?
  game              String?
  sessionId         String?
  deviceId          String?
  truck             String?
  fuelBefore        Float
  fuelAfter         Float
  litresAjoutes     Float
  cuveAvant         Int?
  cuveApres         Int?
  detectedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  moteurEteint      Boolean         @default(false)
  litresPrisCuve    Int             @default(0)
  litresHorsCuve    Int             @default(0)
  prixLitreHorsCuve Decimal         @default(2.30) @db.Decimal(10, 2)
  montantHorsCuve   Decimal         @default(0.00) @db.Decimal(10, 2)
  finances          Finance[]
  mouvements        MouvementCuve[]
  camion            Camion?         @relation(fields: [camionId], references: [id])
  entreprise        Entreprise?     @relation(fields: [entrepriseId], references: [id])
  livraison         Livraison?      @relation(fields: [livraisonId], references: [id])
  user              User            @relation(fields: [steamId], references: [steamId], onDelete: Cascade)

  @@index([steamId])
  @@index([entrepriseId])
  @@index([camionId])
  @@index([livraisonId])
  @@index([detectedAt])
}

model MouvementCuve {
  id           String          @id @default(cuid())
  entrepriseId Int
  pleinId      String?
  chauffeurId  String?
  type         String
  litres       Int
  cuveAvant    Int
  cuveApres    Int
  description  String?
  createdAt    DateTime        @default(now())
  chauffeur    User?           @relation(fields: [chauffeurId], references: [id])
  entreprise   Entreprise      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  plein        PleinCarburant? @relation(fields: [pleinId], references: [id])

  @@index([entrepriseId])
  @@index([pleinId])
  @@index([chauffeurId])
  @@index([createdAt])
  @@index([type])
}

model TackySession {
  id         String   @id @default(cuid())
  userId     String?
  token      String?  @unique
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt
  deviceCode String
  isLinked   Boolean  @default(false)
  requestId  String   @unique
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([deviceCode])
}

model CuveSite {
  id                  Int                      @id @default(1)
  stockActuel         Int                      @default(0)
  capaciteMax         Int                      @default(300000)
  prixActuelLitre     Decimal                  @default(1.95) @db.Decimal(10, 2)
  updatedAt           DateTime                 @updatedAt
  createdAt           DateTime                 @default(now())
  mouvements          MouvementCuveSite[]
  livraisonsCarburant LivraisonCarburantSite[]
  achatsCarburantSite AchatCarburantSite[]
}

model LivraisonCarburantSite {
  id            String   @id @default(cuid())
  cuveSiteId    Int      @default(1)
  livraisonId   String   @unique
  steamId       String
  entrepriseId  Int?
  cargo         String
  litresAjoutes Int      @default(15000)
  stockAvant    Int
  stockApres    Int
  prixAuMoment  Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  cuveSite   CuveSite           @relation(fields: [cuveSiteId], references: [id], onDelete: Cascade)
  livraison  Livraison          @relation(fields: [livraisonId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [steamId], references: [steamId], onDelete: Cascade)
  entreprise Entreprise?        @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
  mouvement  MouvementCuveSite?

  @@index([cuveSiteId])
  @@index([livraisonId])
  @@index([steamId])
  @@index([entrepriseId])
  @@index([createdAt])
}

model MouvementCuveSite {
  id                       String   @id @default(cuid())
  cuveSiteId               Int      @default(1)
  type                     String
  litres                   Int
  stockAvant               Int
  stockApres               Int
  prixLitreAuMoment        Decimal  @db.Decimal(10, 2)
  description              String?
  livraisonCarburantSiteId String?  @unique
  achatCarburantSiteId     String?  @unique
  createdAt                DateTime @default(now())

  cuveSite           CuveSite                @relation(fields: [cuveSiteId], references: [id], onDelete: Cascade)
  livraisonCarburant LivraisonCarburantSite? @relation(fields: [livraisonCarburantSiteId], references: [id], onDelete: SetNull)
  achatCarburant     AchatCarburantSite?     @relation(fields: [achatCarburantSiteId], references: [id], onDelete: SetNull)

  @@index([cuveSiteId])
  @@index([type])
  @@index([createdAt])
}

model AchatCarburantSite {
  id                  String   @id @default(cuid())
  cuveSiteId          Int      @default(1)
  entrepriseId        Int
  litresAchetes       Int
  prixLitre           Decimal  @db.Decimal(10, 2)
  montantTotal        Decimal  @db.Decimal(10, 2)
  stockSiteAvant      Int
  stockSiteApres      Int
  cuveEntrepriseAvant Int
  cuveEntrepriseApres Int
  createdAt           DateTime @default(now())

  cuveSite   CuveSite           @relation(fields: [cuveSiteId], references: [id], onDelete: Cascade)
  entreprise Entreprise         @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  mouvement  MouvementCuveSite?

  @@index([cuveSiteId])
  @@index([entrepriseId])
  @@index([createdAt])
}

model AvertissementEntreprise {
  id           Int      @id @default(autoincrement())
  entrepriseId Int
  membreId     Int
  auteurId     Int
  raison       String
  createdAt    DateTime @default(now())

  entreprise Entreprise       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  membre     EntrepriseMembre @relation("AvertissementMembre", fields: [membreId], references: [id], onDelete: Cascade)
  auteur     EntrepriseMembre @relation("AvertissementAuteur", fields: [auteurId], references: [id], onDelete: Cascade)

  @@index([entrepriseId])
  @@index([membreId])
  @@index([auteurId])
  @@index([createdAt])
}

model CamionEntretien {
  id            Int           @id @default(autoincrement())
  camionId      Int
  entrepriseId  Int
  userId        String?
  type          TypeEntretien
  prix          Int           @default(0)
  kilometrageKm Int           @default(0)
  commentaire   String?
  createdAt     DateTime      @default(now())

  camion     Camion     @relation(fields: [camionId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([camionId])
  @@index([entrepriseId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

model Infraction {
  id              Int      @id @default(autoincrement())
  entrepriseId    Int?
  userId          String?
  camionId        Int?
  steamId         String?
  type            String?
  raison          String?
  montant         Int      @default(0)
  sourceCity      String?
  destinationCity String?
  cargo           String?
  livraisonId     String?
  createdAt       DateTime @default(now())

  entreprise Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  camion     Camion?     @relation(fields: [camionId], references: [id], onDelete: SetNull)

  @@index([entrepriseId])
  @@index([userId])
  @@index([camionId])
  @@index([steamId])
  @@index([createdAt])
}

model TelepeageContrat {
  id           Int      @id @default(autoincrement())
  entrepriseId Int
  camionsMax   Int
  prix         Int
  dateDebut    DateTime @default(now())
  dateFin      DateTime
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@index([entrepriseId])
  @@index([actif])
  @@index([dateFin])
}

enum RoleEntreprise {
  DIRECTEUR
  SOUS_DIRECTEUR
  CHEF_EQUIPE
  CHEF_ATELIER
  CHAUFFEUR
}

enum StatutCandidature {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

enum StatutCamion {
  DISPONIBLE
  EN_MISSION
  EN_MAINTENANCE
}

enum StatutRemorque {
  DISPONIBLE
  ATTRIBUEE
  EN_MAINTENANCE
}

enum MarqueCamion {
  RENAULT
  SCANIA
  VOLVO
  MAN
  DAF
  MERCEDES
  IVECO
  KENWORTH
  PETERBILT
  FREIGHTLINER
  INTERNATIONAL
  MACK
  WESTERN_STAR
}

enum MarqueRemorque {
  KRONE
  SCHMITZ
  KOGEL
  WIELTON
  LAMBERET
  CHEREAU
  FRUEHAUF
  FAYMONVILLE
  NOOTEBOOM
  UTILITY
  GREAT_DANE
  WABASH
  FONTAINE
}

enum TypeRemorque {
  FRIGO
  CITERNE
  PLATEAU
  BACHEE
  BENNE
  PORTE_ENGINS
  PORTE_CONTENEUR
  LOWBOY
  FOURGON
  TAUTLINER
}

enum TypeEntretien {
  VIDANGE
  REVISION
  PNEUS
  FREINS
  BATTERIE
  REPARATION_GENERALE
}

enum TypeEntretienRemorque {
  PNEUS
  CHASSIS
  CAISSE
  CARGAISON
  REPARATION_GENERALE
}

model FinancePerso {
  id          Int      @id @default(autoincrement())
  userId      String
  type        String
  description String
  montant     Int
  livraisonId String?
  camionId    Int?
  pleinId     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([livraisonId])
  @@index([camionId])
  @@index([pleinId])
}