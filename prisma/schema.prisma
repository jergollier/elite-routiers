generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleEntreprise {
  DIRECTEUR
  SOUS_DIRECTEUR
  CHEF_EQUIPE
  CHEF_ATELIER
  CHAUFFEUR
}

enum StatutCandidature {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

model User {
  id                   String                  @id @default(cuid())
  steamId              String                  @unique
  username             String?
  avatar               String?
  age                  Int?
  region               String?
  email                String?                 @unique
  password             String?
  jeuPrincipal         String?
  typeTransportPrefere String?
  descriptionChauffeur String?
  styleConduite        String?
  micro                Boolean                 @default(false)
  createdAt            DateTime                @default(now())

  entreprisesCreees    Entreprise[]            @relation("EntrepriseOwner")
  memberships          EntrepriseMembre[]
  candidatures         EntrepriseCandidature[]
  dlcs                 UserDlc[]
}

model Entreprise {
  id            Int                     @id @default(autoincrement())
  nom           String
  abreviation   String                  @db.VarChar(3)
  villeETS2     String?
  villeATS      String?
  jeu           String
  typeTransport String
  description   String
  recrutement   Boolean                 @default(true)
  banniere      String?
  ownerSteamId  String
  createdAt     DateTime                @default(now())

  argent        Int                     @default(125000)
  cuveActuelle  Int                     @default(6200)
  cuveMax       Int                     @default(10000)

  owner         User                    @relation("EntrepriseOwner", fields: [ownerSteamId], references: [steamId], onDelete: Cascade)
  membres       EntrepriseMembre[]
  candidatures  EntrepriseCandidature[]

  @@index([ownerSteamId])
}

model EntrepriseMembre {
  id           Int             @id @default(autoincrement())
  userId       String
  entrepriseId Int
  role         RoleEntreprise  @default(CHAUFFEUR)
  createdAt    DateTime        @default(now())

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise   Entreprise      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
}

model EntrepriseCandidature {
  id             Int                @id @default(autoincrement())
  userId         String
  entrepriseId   Int
  age            Int?
  region         String?
  jeuPrincipal   String
  experience     String
  micro          Boolean            @default(false)
  disponibilites String?
  motivation     String
  message        String?
  statut         StatutCandidature  @default(EN_ATTENTE)
  createdAt      DateTime           @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise     Entreprise         @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
  @@index([statut])
}

model UserDlc {
  id        Int      @id @default(autoincrement())
  userId    String
  jeu       String
  nomDlc    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jeu, nomDlc])
  @@index([userId])
  @@index([jeu])
}