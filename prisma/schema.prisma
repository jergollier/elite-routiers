generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  steamId      String       @unique
  username     String?
  avatar       String?
  age          Int?
  region       String?
  email        String?      @unique
  password     String?
  createdAt    DateTime     @default(now())
  entreprises  Entreprise[]
}

model Entreprise {
  id             Int      @id @default(autoincrement())
  nom            String
  abreviation    String   @db.VarChar(3)
  villeETS2      String?
  villeATS       String?
  jeu            String
  typeTransport  String
  description    String
  recrutement    Boolean  @default(true)
  banniere       String?
  ownerSteamId   String
  createdAt      DateTime @default(now())

  owner          User     @relation(fields: [ownerSteamId], references: [steamId], onDelete: Cascade)

  @@index([ownerSteamId])
}