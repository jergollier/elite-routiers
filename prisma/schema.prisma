generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleEntreprise {
  DIRECTEUR
  SOUS_DIRECTEUR
  CHEF_EQUIPE
  CHEF_ATELIER
  CHAUFFEUR
}

enum StatutCandidature {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

enum StatutCamion {
  DISPONIBLE
  EN_MISSION
  EN_MAINTENANCE
}

enum MarqueCamion {
  RENAULT
  SCANIA
  VOLVO
  MAN
  DAF
  MERCEDES
  IVECO
  KENWORTH
  PETERBILT
  FREIGHTLINER
  INTERNATIONAL
  MACK
  WESTERN_STAR
}

model User {
  id                   String   @id @default(cuid())
  steamId              String   @unique
  parkingPlaces        Int      @default(0)
  username             String?
  avatar               String?
  age                  Int?
  region               String?
  email                String?  @unique
  password             String?
  jeuPrincipal         String?
  typeTransportPrefere String?
  descriptionChauffeur String?
  styleConduite        String?
  micro                Boolean  @default(false)
  createdAt            DateTime @default(now())

  argent      Int @default(0)
  argentPerso Int @default(0)

  entreprisesCreees Entreprise[]            @relation("EntrepriseOwner")
  memberships       EntrepriseMembre[]
  candidatures      EntrepriseCandidature[]
  dlcs              UserDlc[]
  finances          Finance[]
  camionsAttribues  Camion[]                @relation("CamionsAttribues")
  camionsPerso      Camion[]                @relation("CamionsPerso")
  chauffeurStats    ChauffeurStat[]
  livraisons        Livraison[]
  pleinsCarburant   PleinCarburant[]
  mouvementsCuve    MouvementCuve[]
}

model Entreprise {
  id            Int      @id @default(autoincrement())
  nom           String
  abreviation   String   @db.VarChar(3)
  villeETS2     String?
  villeATS      String?
  jeu           String
  typeTransport String
  description   String
  recrutement   Boolean  @default(true)
  banniere      String?
  ownerSteamId  String
  entrepriseId  String?
  createdAt     DateTime @default(now())

  argent       Int @default(125000)
  cuveActuelle Int @default(6200)
  cuveMax      Int @default(10000)

  owner User @relation("EntrepriseOwner", fields: [ownerSteamId], references: [steamId], onDelete: Cascade)

  membres         EntrepriseMembre[]
  candidatures    EntrepriseCandidature[]
  finances        Finance[]
  camions         Camion[]
  chauffeurStats  ChauffeurStat[]
  livraisons      Livraison[]
  pleinsCarburant PleinCarburant[]
  mouvementsCuve  MouvementCuve[]

  @@index([ownerSteamId])
}

model EntrepriseMembre {
  id           Int            @id @default(autoincrement())
  userId       String
  entrepriseId Int
  role         RoleEntreprise @default(CHAUFFEUR)
  createdAt    DateTime       @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
}

model EntrepriseCandidature {
  id             Int               @id @default(autoincrement())
  userId         String
  entrepriseId   Int
  age            Int?
  region         String?
  jeuPrincipal   String
  experience     String
  micro          Boolean           @default(false)
  disponibilites String?
  motivation     String
  message        String?
  statut         StatutCandidature @default(EN_ATTENTE)
  createdAt      DateTime          @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
  @@index([statut])
}

model UserDlc {
  id        Int      @id @default(autoincrement())
  userId    String
  jeu       String
  nomDlc    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jeu, nomDlc])
  @@index([userId])
  @@index([jeu])
}

model Finance {
  id           Int      @id @default(autoincrement())
  entrepriseId Int
  chauffeurId  String?
  type         String
  description  String
  montant      Int
  createdAt    DateTime @default(now())

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  chauffeur  User?      @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)

  @@index([entrepriseId])
  @@index([chauffeurId])
  @@index([createdAt])
}

model Camion {
  id                   Int          @id @default(autoincrement())
  entrepriseId         Int?
  chauffeurAttribueId  String?
  proprietaireId       String?
  marque               MarqueCamion
  modele               String
  cabine               String?
  chassis              String?
  moteur               String?
  transmission         String?
  peinture             String?
  image                String?
  preuveAchat          String?
  prixAchat            Int?
  accessoiresExterieur String?
  accessoiresInterieur String?
  kilometrage          Int          @default(0)
  etat                 Int          @default(100)
  carburant            Int          @default(100)
  positionActuelle     String?
  statut               StatutCamion @default(DISPONIBLE)
  vidangeRestante      Int          @default(60000)
  revisionRestante     Int          @default(120000)
  actif                Boolean      @default(true)
  createdAt            DateTime     @default(now())

  entreprise        Entreprise?      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  chauffeurAttribue User?            @relation("CamionsAttribues", fields: [chauffeurAttribueId], references: [id], onDelete: SetNull)
  proprietaire      User?            @relation("CamionsPerso", fields: [proprietaireId], references: [id], onDelete: SetNull)
  livraisons        Livraison[]
  pleins            PleinCarburant[]

  @@index([entrepriseId])
  @@index([chauffeurAttribueId])
  @@index([proprietaireId])
  @@index([statut])
}

model ChauffeurStat {
  id           Int    @id @default(autoincrement())
  userId       String
  entrepriseId Int

  argentGagne Int @default(0)
  kilometres  Int @default(0)
  infractions Int @default(0)
  accidents   Int @default(0)
  livraisons  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
}

model ClientEvent {
  id        String   @id @default(cuid())
  type      String
  steamId   String?
  deviceId  String?
  sessionId String?
  game      String?
  payload   Json
  createdAt DateTime @default(now())

  @@index([steamId])
  @@index([deviceId])
  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

model Livraison {
  id           String  @id @default(cuid())
  jobId        String? @unique
  steamId      String
  entrepriseId Int?
  camionId     Int?

  game      String?
  sessionId String?
  deviceId  String?

  truck      String
  truckBrand String?
  truckModel String?
  cargo      String?

  status            String  @default("EN_COURS")
  validatedByServer Boolean @default(false)
  cancelReason      String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  startOdometerKm  Float  @default(0)
  endOdometerKm    Float?
  distanceReelleKm Float  @default(0)

  income        Int     @default(0)
  gainSociete   Int     @default(0)
  gainChauffeur Int     @default(0)
  charges       Int     @default(0)
  argentAjoute  Boolean @default(false)

  sourceCity      String?
  destinationCity String?
  kmPrevu         Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User             @relation(fields: [steamId], references: [steamId], onDelete: Cascade)
  entreprise Entreprise?      @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
  camion     Camion?          @relation(fields: [camionId], references: [id], onDelete: SetNull)
  pleins     PleinCarburant[]

  @@index([steamId])
  @@index([entrepriseId])
  @@index([camionId])
  @@index([status])
  @@index([startedAt])
  @@index([finishedAt])
}

model PleinCarburant {
  id           String  @id @default(cuid())
  steamId      String
  entrepriseId Int?
  camionId     Int?
  livraisonId  String?

  game      String?
  sessionId String?
  deviceId  String?

  truck         String?
  fuelBefore    Float
  fuelAfter     Float
  litresAjoutes Float

  cuveAvant Int?
  cuveApres Int?

  detectedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user       User            @relation(fields: [steamId], references: [steamId], onDelete: Cascade)
  entreprise Entreprise?     @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
  camion     Camion?         @relation(fields: [camionId], references: [id], onDelete: SetNull)
  livraison  Livraison?      @relation(fields: [livraisonId], references: [id], onDelete: SetNull)
  mouvements MouvementCuve[]

  @@index([steamId])
  @@index([entrepriseId])
  @@index([camionId])
  @@index([livraisonId])
  @@index([detectedAt])
}

model MouvementCuve {
  id           String  @id @default(cuid())
  entrepriseId Int
  pleinId      String?
  chauffeurId  String?

  type        String
  litres      Int
  cuveAvant   Int
  cuveApres   Int
  description String?
  createdAt   DateTime @default(now())

  entreprise Entreprise      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  plein      PleinCarburant? @relation(fields: [pleinId], references: [id], onDelete: SetNull)
  chauffeur  User?           @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)

  @@index([entrepriseId])
  @@index([pleinId])
  @@index([chauffeurId])
  @@index([createdAt])
}
