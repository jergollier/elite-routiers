generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleEntreprise {
  DIRECTEUR
  SOUS_DIRECTEUR
  CHEF_EQUIPE
  CHEF_ATELIER
  CHAUFFEUR
}

enum StatutCandidature {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

enum StatutCamion {
  DISPONIBLE
  EN_MISSION
  EN_MAINTENANCE
}

enum MarqueCamion {
  RENAULT
  SCANIA
  VOLVO
  MAN
  DAF
  MERCEDES
  IVECO
  KENWORTH
  PETERBILT
  FREIGHTLINER
  INTERNATIONAL
  MACK
  WESTERN_STAR
}

model User {
  id                   String   @id @default(cuid())
  steamId              String   @unique
  username             String?
  avatar               String?
  age                  Int?
  region               String?
  email                String?  @unique
  password             String?
  jeuPrincipal         String?
  typeTransportPrefere String?
  descriptionChauffeur String?
  styleConduite        String?
  micro                Boolean  @default(false)
  createdAt            DateTime @default(now())

  entreprisesCreees Entreprise[]            @relation("EntrepriseOwner")
  memberships       EntrepriseMembre[]
  candidatures      EntrepriseCandidature[]
  dlcs              UserDlc[]
  finances          Finance[]
  camionsAttribues  Camion[]
  chauffeurStats    ChauffeurStat[]
}

model Entreprise {
  id            Int      @id @default(autoincrement())
  nom           String
  abreviation   String   @db.VarChar(3)
  villeETS2     String?
  villeATS      String?
  jeu           String
  typeTransport String
  description   String
  recrutement   Boolean  @default(true)
  banniere      String?
  ownerSteamId  String
  createdAt     DateTime @default(now())

  argent       Int @default(125000)
  cuveActuelle Int @default(6200)
  cuveMax      Int @default(10000)

  owner          User                    @relation("EntrepriseOwner", fields: [ownerSteamId], references: [steamId], onDelete: Cascade)
  membres        EntrepriseMembre[]
  candidatures   EntrepriseCandidature[]
  finances       Finance[]
  camions        Camion[]
  chauffeurStats ChauffeurStat[]

  @@index([ownerSteamId])
}

model EntrepriseMembre {
  id           Int            @id @default(autoincrement())
  userId       String
  entrepriseId Int
  role         RoleEntreprise @default(CHAUFFEUR)
  createdAt    DateTime       @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
}

model EntrepriseCandidature {
  id             Int               @id @default(autoincrement())
  userId         String
  entrepriseId   Int
  age            Int?
  region         String?
  jeuPrincipal   String
  experience     String
  micro          Boolean           @default(false)
  disponibilites String?
  motivation     String
  message        String?
  statut         StatutCandidature @default(EN_ATTENTE)
  createdAt      DateTime          @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
  @@index([statut])
}

model UserDlc {
  id        Int      @id @default(autoincrement())
  userId    String
  jeu       String
  nomDlc    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jeu, nomDlc])
  @@index([userId])
  @@index([jeu])
}

model Finance {
  id           Int      @id @default(autoincrement())
  entrepriseId Int
  chauffeurId  String?
  type         String
  description  String
  montant      Int
  createdAt    DateTime @default(now())

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  chauffeur  User?      @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)

  @@index([entrepriseId])
  @@index([chauffeurId])
  @@index([createdAt])
}

model Camion {
  id                   Int          @id @default(autoincrement())
  entrepriseId         Int
  chauffeurId          String?
  marque               MarqueCamion
  modele               String
  cabine               String?
  chassis              String?
  moteur               String?
  transmission         String?
  peinture             String?
  image                String?
  preuveAchat          String?
  prixAchat            Int?
  accessoiresExterieur String?
  accessoiresInterieur String?
  kilometrage          Int          @default(0)
  etat                 Int          @default(100)
  carburant            Int          @default(100)
  positionActuelle     String?
  statut               StatutCamion @default(DISPONIBLE)
  vidangeRestante      Int          @default(60000)
  revisionRestante     Int          @default(120000)
  actif                Boolean      @default(true)
  createdAt            DateTime     @default(now())

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  chauffeur  User?      @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)

  @@index([entrepriseId])
  @@index([chauffeurId])
  @@index([statut])
}

model ChauffeurStat {
  id           Int    @id @default(autoincrement())
  userId       String
  entrepriseId Int

  argentGagne Int @default(0)
  kilometres  Int @default(0)
  infractions Int @default(0)
  accidents   Int @default(0)
  livraisons  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([userId, entrepriseId])
  @@index([entrepriseId])
  @@index([userId])
}
model ClientEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())
}
model Livraison {
  id              String   @id @default(cuid())
  jobId           String   @unique
  truck           String
  sourceCity      String
  destinationCity String
  cargo           String
  income          Int
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  status          String   @default("EN_COURS")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}